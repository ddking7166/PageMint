{
  "name": "pagemint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm run build && pnpm -r --sort typecheck",
    "test": "pnpm run build && vitest run",
    "dev:basic": "pnpm --filter @pagemint/example-basic dev"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
